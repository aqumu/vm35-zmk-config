#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

/*
 * VM35 standalone macropad — 7 rows x 5 columns, laid out in physical
 * order (top-left first, reading left->right, top->bottom).
 *
 * This base layer is a POSITION TEST: every key types a unique symbol so
 * we can confirm the physical layout is correct. Read across the top row —
 * it should type 1 2 3 4 5 left-to-right. Once confirmed, we replace this
 * with your real layout.
 *
 * Bottom-right key is the Fn/layer key (&mo 1) — it won't type a letter.
 */

/ {
	keymap {
		compatible = "zmk,keymap";

		default_layer {
			display-name = "Test";
			bindings = <
				&kp N1  &kp N2  &kp N3  &kp N4  &kp N5
				&kp N6  &kp N7  &kp N8  &kp N9  &kp N0
				&kp Q   &kp W   &kp E   &kp R   &kp T
				&kp A   &kp S   &kp D   &kp F   &kp G
				&kp Z   &kp X   &kp C   &kp V   &kp B
				&kp Y   &kp U   &kp I   &kp O   &kp P
				&kp H   &kp J   &kp K   &kp L   &mo 1
			>;
		};

		fn_layer {
			display-name = "Fn";
			bindings = <
				&bt BT_CLR   &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3
				&out OUT_USB &out OUT_BLE  &out OUT_TOG  &trans        &trans
				&trans       &trans        &trans        &trans        &trans
				&trans       &trans        &trans        &trans        &trans
				&trans       &trans        &trans        &trans        &trans
				&trans       &trans        &trans        &trans        &trans
				&trans       &trans        &trans        &trans        &trans
			>;
		};
	};
};
