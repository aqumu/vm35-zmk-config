/*
 * VM35 — custom macropad (standalone) built on an nRF52840
 * (EByte E73-2G4M08S1C module).
 */

/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>

/ {
	model = "VM35";
	compatible = "vm,vm35";

	chosen {
		zephyr,code-partition = &code_partition;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zmk,kscan = &kscan0;
		zmk,matrix-transform = &default_transform;
		zmk,battery = &vbatt;
	};

	/* Li-ion voltage divider on P0.04/AIN2: VBAT -[820k]- ADC -[2M]- GND. */
	vbatt: vbatt {
		compatible = "zmk,battery-voltage-divider";
		io-channels = <&adc 2>;
		output-ohms = <2000000>;
		full-ohms = <2820000>;
	};

	/*
	 * External-power gate: P-FET (AO3407) gate on P1.09, held off by a 2M
	 * pull-up, so driving the pin low enables EXT_VCC -> ACTIVE_LOW.
	 * Polarity is inferred from the schematic; verify on hardware.
	 */
	extpower {
		compatible = "zmk,ext-power-generic";
		control-gpios = <&gpio1 9 GPIO_ACTIVE_LOW>;
		label = "EXT_POWER";
	};

	/*
	 * 7x5 matrix, diodes col->row (anode on column, cathode on row),
	 * so columns are driven and rows are read. Pin map recovered from
	 * the daughterboard netlist + motherboard PCB:
	 *
	 *   FPC pin  net    nRF pin
	 *   1        row6   P0.03
	 *   2        row5   P1.13
	 *   3        row4   P0.02
	 *   4        row3   P0.29
	 *   5        row2   P0.31
	 *   6        row1   P0.30
	 *   7        row0   P0.28
	 *   8        col0   P0.22
	 *   9        col1   P0.13
	 *   10       col2   P0.20
	 *   11       col3   P0.17
	 *   12       col4   P0.15
	 */
	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		wakeup-source;
		diode-direction = "col2row";

		row-gpios
			= <&gpio0 28 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row0 */
			, <&gpio0 30 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row1 */
			, <&gpio0 31 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row2 */
			, <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row3 */
			, <&gpio0  2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row4 */
			, <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row5 */
			, <&gpio0  3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row6 */
			;

		col-gpios
			= <&gpio0 22 GPIO_ACTIVE_HIGH>	/* col0 */
			, <&gpio0 13 GPIO_ACTIVE_HIGH>	/* col1 */
			, <&gpio0 20 GPIO_ACTIVE_HIGH>	/* col2 */
			, <&gpio0 17 GPIO_ACTIVE_HIGH>	/* col3 */
			, <&gpio0 15 GPIO_ACTIVE_HIGH>	/* col4 */
			;
	};

	/* Standalone macropad: plain 7-row x 5-col grid, 35 keys. */
	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <5>;
		rows = <7>;
		map = <
			RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
			RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
			RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
			RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)
			RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4)
			RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,4)
			RC(6,0) RC(6,1) RC(6,2) RC(6,3) RC(6,4)
		>;
	};
};

&adc {
	status = "okay";
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&usbd {
	status = "okay";
};

&flash0 {
	/*
	 * Partition layout for the Adafruit nRF52 (UF2) bootloader,
	 * same as nice!nano. Application starts at 0x26000.
	 */
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		sd_partition: partition@0 {
			reg = <0x00000000 0x00026000>;
		};
		code_partition: partition@26000 {
			reg = <0x00026000 0x000c6000>;
		};
		storage_partition: partition@ec000 {
			label = "storage";
			reg = <0x000ec000 0x00008000>;
		};
		boot_partition: partition@f4000 {
			reg = <0x000f4000 0x0000c000>;
		};
	};
};
