/*
 * VM35 — custom macropad (standalone) built on an nRF52840
 * (EByte E73-2G4M08S1C module).
 */

/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
	model = "VM35";
	compatible = "vm,vm35";

	chosen {
		zephyr,code-partition = &code_partition;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zmk,kscan = &kscan0;
		zmk,matrix-transform = &default_transform;
		zmk,battery = &vbatt;
	};

	/* Li-ion voltage divider on P0.04/AIN2: VBAT -[820k]- ADC -[2M]- GND. */
	vbatt: vbatt {
		compatible = "zmk,battery-voltage-divider";
		io-channels = <&adc 2>;
		output-ohms = <2000000>;
		full-ohms = <2820000>;
	};

	/*
	 * External-power gate: P-FET (AO3407) gate on P1.09, held off by a 2M
	 * pull-up, so driving the pin low enables EXT_VCC -> ACTIVE_LOW.
	 * Polarity is inferred from the schematic; verify on hardware.
	 */
	extpower {
		compatible = "zmk,ext-power-generic";
		control-gpios = <&gpio1 9 GPIO_ACTIVE_LOW>;
		label = "EXT_POWER";
	};

	/*
	 * 7x5 matrix. Pin map from the authoritative E73 daughterboard
	 * schematic (net names align DB<->MB despite the reversed FPC order):
	 *
	 *   net    nRF pin      port/pin
	 *   row0   P1.00        gpio1 0
	 *   row1   P0.10/NFC2   gpio0 10   <- needs NFCT_PINS_AS_GPIOS
	 *   row2   P1.06        gpio1 6
	 *   row3   P0.09/NFC1   gpio0 9    <- needs NFCT_PINS_AS_GPIOS
	 *   row4   P1.04        gpio1 4
	 *   row5   P1.02        gpio1 2
	 *   row6   P0.24        gpio0 24
	 *   col0   P0.15        gpio0 15
	 *   col1   P0.17        gpio0 17
	 *   col2   P0.20        gpio0 20
	 *   col3   P0.22        gpio0 22
	 *   col4   P0.13        gpio0 13
	 */
	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		wakeup-source;
		diode-direction = "col2row";

		/* col2row: columns driven (outputs), rows read (inputs with
		 * pull-down). Matches the original working firmware. */
		row-gpios
			= <&gpio1  0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row0 P1.00 */
			, <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row1 P0.10/NFC2 */
			, <&gpio1  6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row2 P1.06 */
			, <&gpio0  9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row3 P0.09/NFC1 */
			, <&gpio1  4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row4 P1.04 */
			, <&gpio1  2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row5 P1.02 */
			, <&gpio0 24 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>	/* row6 P0.24 */
			;

		col-gpios
			= <&gpio0 15 GPIO_ACTIVE_HIGH>	/* col0 P0.15 */
			, <&gpio0 17 GPIO_ACTIVE_HIGH>	/* col1 P0.17 */
			, <&gpio0 20 GPIO_ACTIVE_HIGH>	/* col2 P0.20 */
			, <&gpio0 22 GPIO_ACTIVE_HIGH>	/* col3 P0.22 */
			, <&gpio0 13 GPIO_ACTIVE_HIGH>	/* col4 P0.13 */
			;
	};

	/*
	 * Standalone macropad, 35 keys. Columns are mirrored on the PCB
	 * (physical left = col4), so the transform reverses columns to make
	 * keymap position 0 the physical top-left key and author left->right.
	 */
	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <5>;
		rows = <7>;
		map = <
			RC(0,4) RC(0,3) RC(0,2) RC(0,1) RC(0,0)
			RC(1,4) RC(1,3) RC(1,2) RC(1,1) RC(1,0)
			RC(2,4) RC(2,3) RC(2,2) RC(2,1) RC(2,0)
			RC(3,4) RC(3,3) RC(3,2) RC(3,1) RC(3,0)
			RC(4,4) RC(4,3) RC(4,2) RC(4,1) RC(4,0)
			RC(5,4) RC(5,3) RC(5,2) RC(5,1) RC(5,0)
			RC(6,4) RC(6,3) RC(6,2) RC(6,1) RC(6,0)
		>;
	};

	/*
	 * Physical layout for ZMK Studio (live remapping). Plain 5-wide x
	 * 7-tall 1u grid, keys listed in keymap-position order (top-left
	 * first, left->right) so they line up with default_transform.
	 * Units are 1/100 of a key; 100 = 1u.
	 */
	vm35_layout: vm35_layout {
		compatible = "zmk,physical-layout";
		display-name = "Numpad";
		transform = <&default_transform>;
		keys
			= <&key_physical_attrs 100 100    0    0 0 0 0>
			, <&key_physical_attrs 100 100  100    0 0 0 0>
			, <&key_physical_attrs 100 100  200    0 0 0 0>
			, <&key_physical_attrs 100 100  300    0 0 0 0>
			, <&key_physical_attrs 100 100  400    0 0 0 0>
			, <&key_physical_attrs 100 100    0  100 0 0 0>
			, <&key_physical_attrs 100 100  100  100 0 0 0>
			, <&key_physical_attrs 100 100  200  100 0 0 0>
			, <&key_physical_attrs 100 100  300  100 0 0 0>
			, <&key_physical_attrs 100 100  400  100 0 0 0>
			, <&key_physical_attrs 100 100    0  200 0 0 0>
			, <&key_physical_attrs 100 100  100  200 0 0 0>
			, <&key_physical_attrs 100 100  200  200 0 0 0>
			, <&key_physical_attrs 100 100  300  200 0 0 0>
			, <&key_physical_attrs 100 100  400  200 0 0 0>
			, <&key_physical_attrs 100 100    0  300 0 0 0>
			, <&key_physical_attrs 100 100  100  300 0 0 0>
			, <&key_physical_attrs 100 100  200  300 0 0 0>
			, <&key_physical_attrs 100 100  300  300 0 0 0>
			, <&key_physical_attrs 100 100  400  300 0 0 0>
			, <&key_physical_attrs 100 100    0  400 0 0 0>
			, <&key_physical_attrs 100 100  100  400 0 0 0>
			, <&key_physical_attrs 100 100  200  400 0 0 0>
			, <&key_physical_attrs 100 100  300  400 0 0 0>
			, <&key_physical_attrs 100 100  400  400 0 0 0>
			, <&key_physical_attrs 100 100    0  500 0 0 0>
			, <&key_physical_attrs 100 100  100  500 0 0 0>
			, <&key_physical_attrs 100 100  200  500 0 0 0>
			, <&key_physical_attrs 100 100  300  500 0 0 0>
			, <&key_physical_attrs 100 100  400  500 0 0 0>
			, <&key_physical_attrs 100 100    0  600 0 0 0>
			, <&key_physical_attrs 100 100  100  600 0 0 0>
			, <&key_physical_attrs 100 100  200  600 0 0 0>
			, <&key_physical_attrs 100 100  300  600 0 0 0>
			, <&key_physical_attrs 100 100  400  600 0 0 0>
			;
	};
};

&adc {
	status = "okay";
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

/* Label the USB device controller zephyr_udc0 so the ZMK Studio
 * (studio-rpc-usb-uart) snippet can attach its CDC-ACM RPC endpoint. */
zephyr_udc0: &usbd {
	status = "okay";
};

&flash0 {
	/*
	 * Partition layout for the Adafruit nRF52 (UF2) bootloader,
	 * same as nice!nano. Application starts at 0x26000.
	 */
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		sd_partition: partition@0 {
			reg = <0x00000000 0x00026000>;
		};
		code_partition: partition@26000 {
			reg = <0x00026000 0x000c6000>;
		};
		storage_partition: partition@ec000 {
			label = "storage";
			reg = <0x000ec000 0x00008000>;
		};
		boot_partition: partition@f4000 {
			reg = <0x000f4000 0x0000c000>;
		};
	};
};
